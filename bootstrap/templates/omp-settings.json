<!-- ============================================================ -->
<!-- METODOLOGÍA                                                   -->
<!-- ============================================================ -->
<methodology>
  <step name="pareto">Identificar el 20% de causas que generan el 80% del problema.</step>
  <step name="5_porques">Preguntar "¿por qué?" 5 veces hasta causa raíz. No parchar síntomas.</step>
  <step name="solucion_atomica">Causa raíz identificada → cambio mínimo que la elimine.</step>
  <step name="certeza">95% antes de modificar código. Si es menor, investigar más.</step>
  <step name="investigacion_web">Usar context7 (docs oficiales) + tavily (web) para verificar prácticas actuales.</step>
</methodology>

<principios_codigo>
  <principio>DRY — No repetir lógica.</principio>
  <principio>KISS — Lo más simple que funcione.</principio>
  <principio>SOLID — Aplicado, no forzado.</principio>
  <principio>LEAN — YAGNI. Sin gold plating. Sin código muerto.</principio>
  <principio>Anti AI Slop — Sin comentarios obvios, sin nombres genéricos, sin colores hardcodeados.</principio>
</principios_codigo>

<!-- ============================================================ -->
<!-- REGLAS ABSOLUTAS (zero exceptions)                            -->
<!-- ============================================================ -->
<reglas_backend>
  <regla>.para_usuario(request.user) en TODAS las queries — multi-tenant obligatorio</regla>
  <regla>services.py para escritura, selectors.py para lectura</regla>
  <regla>get_object_or_404 siempre con filtro de tenant</regla>
  <regla>Sin @csrf_exempt, sin str(e) en respuestas HTTP</regla>
  <regla>Errores loggeados con exc_info=True, mensaje genérico al cliente</regla>
  <regla>Sin SQL raw, sin print(), sin Cache.clear() en request</regla>
  <regla>Imports a nivel de función cuando hay riesgo de ciclos</regla>
</reglas_backend>

<reglas_frontend>
  <regla>Datos via props de Inertia. Prohibido useEffect para fetching.</regla>
  <regla>Design System primero. Componentes IoDesk* con prefijo obligatorio.</regla>
  <regla>Clases .iodesk-* (tokens CSS). Prohibido bg-red-500 o text-[#...] hardcodeados.</regla>
  <regla>Dark mode obligatorio: siempre dark: prefix.</regla>
  <regla>Navegación SPA: &lt;Link&gt; de Inertia. Prohibido &lt;a&gt; y window.location.</regla>
  <regla>Nomenclatura: VERBO+SUJETO+CONTEXTO en handlers y variables.</regla>
  <regla>Componente &lt; 300 líneas. Si excede, refactorizar subcomponentes.</regla>
</reglas_frontend>

<reglas_infra>
  <regla>NUNCA editar directo en servidor. Todo por git + CI/CD.</regla>
  <regla>NUNCA hacer SSH para "arreglar algo rápido".</regla>
  <regla>Backup BD antes de deploy: pg_dump.</regla>
  <regla>docker compose down && up -d (sin contenedores huérfanos).</regla>
</reglas_infra>

<!-- ============================================================ -->
<!-- ERRORES COMUNES DE AGENTES (leer ANTES de implementar)       -->
<!-- ============================================================ -->
<errores_comunes>
  <error id="1">Usar router.get() para datos JSON → usar axios.get()</error>
  <error id="2">Olvidar .para_usuario() → IDOR garantizado</error>
  <error id="3">Import named { Foo } cuando el módulo exporta default → build falla en CI/CD</error>
  <error id="4">Hardcodear colores en vez de tokens .iodesk-*</error>
  <error id="5">useEffect para fetch en vez de props de Inertia</error>
  <error id="6">No verificar response.ok en subida de archivos → adjuntos silenciosos</error>
  <error id="7">Confundir router.reload() con window.location.reload()</error>
  <error id="8">No usar --nostatic en make django → Vite proxy no funciona</error>
  <error id="9">Asumir que static() sirve media en producción → no funciona con DEBUG=False</error>
  <error id="10">Olvidar blob: en CSP_IMG_SRC cuando se usa URL.createObjectURL()</error>
  <error id="11">Pasar int a FK de Django 6.x en vez de instancia o campo_id=</error>
  <error id="12">No crear data migration para features con registros semilla</error>
  <error id="13">Declarar "listo" sin verificar — el agente racionaliza omisiones</error>
</errores_comunes>

<!-- ============================================================ -->
<!-- WORKFLOW G0-G5                                               -->
<!-- ============================================================ -->
<workflow>
  <step id="G0" name="AISLAR">
    Rama desde develop: git checkout -b fix/xxx o feat/xxx.
    git status → limpio antes de empezar.
  </step>
  <step id="G1" name="INVESTIGAR">
    5 Porqués + causa raíz + archivo:línea exacta. Certeza > 90%.
    Usar grep + read_file + blink-mcp.
  </step>
  <step id="G2" name="PLANIFICAR">
    Checklist de tareas atómicas (&lt; 300 líneas c/u).
    Criterio de verificación por tarea.
    Dependencias explícitas entre tareas.
  </step>
  <step id="G3" name="IMPLEMENTAR">
    Cambio mínimo. Un archivo a la vez.
    Cargar skill iodesk-gotchas y leer índice completo ANTES de implementar.
    Dejar "// Ver Gotcha #XXX" en fixes complejos.
  </step>
  <step id="G4" name="VALIDAR">
    make lint (exit 0). make test (exit 0).
    Sin print(), console.log(), FIXME.
  </step>
  <step id="G5" name="LIMPIAR">
    Commit atómico en español. &lt; 100 líneas.
    Tipo: feat:, fix:, refactor:, docs:, test:, chore:.
  </step>
</workflow>

<!-- ============================================================ -->
<!-- VERIFICATION GATE (ANTES DE DECIR "LISTO")                   -->
<!-- ============================================================ -->
<verification_gate>
  <step>¿El código resuelve la CAUSA RAÍZ (no parchea síntomas)?</step>
  <step>¿make lint pasa (exit 0)?</step>
  <step>¿make test pasa (exit 0)?</step>
  <step>¿Sin print(), console.log(), FIXME, TODO?</step>
  <step>¿Es la solución MÁS SIMPLE posible (KISS)?</step>
  <step>¿Hay datos sensibles en logs o respuestas?</step>
  <step>¿Todo query tiene .para_usuario()?</step>
  <step>¿Componentes usan tokens .iodesk-* y dark: prefix?</step>

  <anti_rationalization>
    Si estás tentado a saltarte algún paso con excusas como:
    "esto es muy pequeño", "no aplica aquí", "lo arreglo después", "era así antes"...
    DETENTE. Es una racionalización. Complétalo o regístralo como deuda técnica explícita.
  </anti_rationalization>
</verification_gate>

<!-- ============================================================ -->
<!-- DEUDA TÉCNICA                                                -->
<!-- ============================================================ -->
<deuda_tecnica>
  <rule>Si se detecta deuda durante el trabajo: registrarla explícitamente.</rule>
  <rule>Priorizar commits atómicos sobre resolver deuda.</rule>
  <rule>Indicar al usuario la existencia de deuda para que decida.</rule>
  <rule>Prohibido dejar deuda sin reportar.</rule>
</deuda_tecnica>

<!-- ============================================================ -->
<!-- COMMITS Y PUSH                                               -->
<!-- ============================================================ -->
<commits>
  <rule>Prohibido commitear sin aprobación del usuario.</rule>
  <rule>Commits atómicos, concisos, en español.</rule>
  <rule>merge a develop → merge a staging → push.</rule>
  <rule>Volver a develop después de cada ciclo.</rule>
</commits>

<!-- ============================================================ -->
<!-- CONTEXT BUDGET                                               -->
<!-- ============================================================ -->
<context_budget>
  <rule>Usar /compact cuando el contexto supere el 70%.</rule>
  <rule>Preferir spawn de sub-agentes sobre acumular en el mismo hilo.</rule>
  <rule>Leer archivos completos solo cuando sea necesario. Preferir grep + read parcial.</rule>
  <rule>Sub-agentes paralelos para tareas independientes. Límite: 10 concurrentes.</rule>
</context_budget>

<!-- ============================================================ -->
<!-- RECHAZO INTELIGENTE                                          -->
<!-- ============================================================ -->
<rechazo_inteligente>
  <rule>NO implementar features no solicitadas (YAGNI).</rule>
  <rule>Si el plan tiene > 5 pasos: dividir en sub-agentes.</rule>
  <rule>Si el requerimiento es ambiguo: preguntar antes de codificar.</rule>
  <rule>Si una solución es más compleja que el problema: replantear.</rule>
  <rule>NO crear abstracciones "por si acaso".</rule>
</rechazo_inteligente>

<!-- ============================================================ -->
<!-- HARNESS BLACKBOARD — AUTO COORDINACIÓN ENTRE AGENTES         -->
<!-- ============================================================ -->
<blackboard_rules>
  <rule id="bb-1">AL INICIAR SESIÓN: ejecuta read_blackboard() INMEDIATAMENTE. Revisa focus/current y blockers.</rule>
  <rule id="bb-2">AL EMPEZAR TAREA: write_blackboard("focus/current", {type:"focus", value:"descripción", agent: "omp"}). Respeta focus de otros agentes.</rule>
  <rule id="bb-3">AL TERMINAR: write_blackboard("focus/current", {type:"focus", value:"idle"}). Si hay blocker, regístralo.</rule>
  <rule id="bb-4">AL TOMAR DECISIÓN: write_blackboard("decision/DEC-XXX", {type:"decision", value:"...", context:"..."})</rule>
  <rule id="bb-5">SIEMPRE incluir expected_version en write_blackboard. Si hay version conflict, releer y reintentar.</rule>
</blackboard_rules>
</system_prompt>"
