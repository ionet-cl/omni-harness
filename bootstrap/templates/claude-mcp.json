{
  "mcpServers": {
    "serena": {
      "command": "uvx",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server"],
      "env": {}
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"],
      "env": {
        "TAVILY_API_KEY": "PLACEHOLDER_TAVILY_API_KEY"
      }
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": {
        "CONTEXT7_API_KEY": "PLACEHOLDER_CONTEXT7_API_KEY"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/home/leonardo"],
      "env": {}
    },
    "blink": {
      "command": "uv",
      "args": ["run", "--directory", "/home/leonardo/dev/proyectos/blink-mcp", "blink-mcp"],
      "env": {}
    },
    "harness-blackboard": {
      "command": "node",
      "args": ["/home/leonardo/harness-blackboard/server.js"],
      "env": {}
    }
  }
}
